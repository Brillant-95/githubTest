select* from AprSales limit 5;
select* from BIT_DB.customers where length(order_id)=6 and order_id<>'Order ID';
select* from FebSales limit 5;
select* from MarSales limit 5;
select* from MaySales limit 5;
select* from JanSales limit 5;

select count(distinct orderid)
from BIT_DB.JanSales
where length(orderid)=6
and orderid<>'Order id'
and product='iPhone';

select count(distinct product)
from BIT_DB.JanSales
where length(orderid)=6
and orderid<>'Order id';

select  FebSales.orderID,customers.acctnum
from FebSales
left join customers
on FebSales.orderID=customers.order_id
where length(orderid)=6
and orderid<>'order id';

select distinct acctnum
from BIT_DB.customers cust
inner join BIT_DB.FebSales Febs
on cust.order_id=Febs.orderID
where length(orderid)=6
and orderid<>'order id';

select min(JanSales.price), JanSales.Product
from BIT_DB.JanSales
where length(orderid)=6
and orderid<>'order id';

select distinct JanSales.Product, price
from BIT_DB.JanSales
Where JanSales.price=(select min(JanSales.price) from BIT_DB.JanSales where length(orderid)=6
and orderid<>'order id');

select min(price), product
from JanSales
group by product, price
order by price asc
limit 1;

select sum(quantity)*price totalrev, product
from JanSales
group by product;

SELECT orderid, quantity, price, product
FROM BIT_DB.JanSales;

SELECT SUM(quantity), price, product
FROM BIT_DB.JanSales
GROUP BY product, price;

SELECT SUM(quantity)*price as Revenue
,product
FROM BIT_DB.JanSales
GROUP BY product;

select product, sum(quantity), sum(quantity)*price as revenue
from BIT_DB.FebSales
where FebSales.location= '548 Lincoln St, Seattle, WA 98101'
group by product;

SELECT
sum(Quantity),
product,
sum(quantity)*price as revenue
FROM BIT_DB.FebSales
WHERE location = '548 Lincoln St, Seattle, WA 98101'
GROUP BY product;

SELECT
count(distinct cust.acctnum),
avg(quantity*price)
FROM BIT_DB.FebSales Feb
LEFT JOIN BIT_DB.customers cust
ON FEB.orderid=cust.order_id
WHERE Feb.Quantity>2
AND length(orderid) = 6
AND orderid <> 'Order ID';

