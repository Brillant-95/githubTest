--Which product brought in the most revenue in January and how much revenue did it bring in total?

--In other words, show the one product that generated the most revenue (revenue being equivalent to quantity of an item multiplied by the item’s price). 

select product, sum(quantity*price) revenue
from Jansales
group by product
order by revenue desc
limit 1;

select distinct product, sum(quantity)*price revenue
from Jansales
group by product
order by revenue desc
limit 1;
